<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_medium_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_white"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/widget_medium_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_book_heart_navy"
            android:contentDescription="@null" />
        <LinearLayout android:layout_width="6dp" android:layout_height="1dp" />
        <TextView
            android:id="@+id/widget_medium_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#333333"
            android:textSize="14sp"
            android:fontFamily="@font/wanted_sans_semibold"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="8dp" />

    <TextView
        android:id="@+id/widget_medium_reason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#333333"
        android:textSize="12sp"
        android:fontFamily="@font/wanted_sans_regular"
        android:maxLines="3"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/widget_medium_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#010196"
        android:textSize="12sp"
        android:fontFamily="@font/dunggeunmo"
        android:gravity="end" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <ImageView
            android:id="@+id/widget_medium_dot_0"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/dot_white_inactive"
            android:contentDescription="@null" />
        <ImageView
            android:id="@+id/widget_medium_dot_1"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/dot_white_inactive"
            android:contentDescription="@null" />
        <ImageView
            android:id="@+id/widget_medium_dot_2"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/dot_white_inactive"
            android:contentDescription="@null" />
        <ImageView
            android:id="@+id/widget_medium_dot_3"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/dot_white_inactive"
            android:contentDescription="@null" />
        <ImageView
            android:id="@+id/widget_medium_dot_4"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:src="@drawable/dot_white_inactive"
            android:contentDescription="@null" />
    </LinearLayout>
</LinearLayout>
