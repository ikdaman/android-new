<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="250dp"
    android:layout_height="110dp"
    android:background="@drawable/widget_bg_white"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_book_heart_navy"
                android:contentDescription="@null" />
            <LinearLayout
                android:layout_width="4dp"
                android:layout_height="1dp" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="책 제목"
                android:textColor="#333333"
                android:textSize="13sp"
                android:fontFamily="@font/wanted_sans_regular"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="읽고 싶은 이유를 추가해 주세요."
            android:textColor="#A7A7A7"
            android:textSize="11sp"
            android:fontFamily="@font/wanted_sans_regular"
            android:maxLines="3"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026.05.16"
            android:textColor="#010196"
            android:textSize="11sp"
            android:fontFamily="@font/dunggeunmo" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="6dp"
            android:text="이전"
            android:textColor="#010196"
            android:textSize="11sp"
            android:fontFamily="@font/dunggeunmo" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="|"
            android:textColor="#010196"
            android:textSize="11sp"
            android:fontFamily="@font/dunggeunmo" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="6dp"
            android:text="다음"
            android:textColor="#010196"
            android:textSize="11sp"
            android:fontFamily="@font/dunggeunmo" />
    </LinearLayout>
</FrameLayout>
