<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_small_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_white"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:id="@+id/widget_small_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_book_heart_navy"
            android:contentDescription="@null" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />
        <ImageView
            android:id="@+id/widget_small_refresh"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_widget_refresh_dark"
            android:contentDescription="@null" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="10dp" />

    <TextView
        android:id="@+id/widget_small_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#333333"
        android:textSize="14sp"
        android:fontFamily="@font/wanted_sans_semibold"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingExtra="-2sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/widget_small_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#010196"
        android:textSize="11sp"
        android:fontFamily="@font/dunggeunmo"
        android:gravity="end" />
</LinearLayout>
